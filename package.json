{
	"name": "navigation-demo",
	"description": "React Native Navigation that supports seamless navigation between Native and React.",
	"version": "2.0.0",
	"private": true,
	"scripts": {
		"start": "react-native start --reset-cache",
		"android": "react-native run-android",
		"ios": "react-native run-ios",
		"test": "jest",
		"test:rotate:ios": "bash tests/rotation/ios-rotation-smoke.sh",
		"test:rotate:ios:regression": "bash tests/rotation/ios-rotation-regression.sh",
		"test:rotate:android": "bash tests/rotation/android-rotation-smoke.sh",
		"test:rotate:android:regression": "bash tests/rotation/android-rotation-regression.sh",
		"tsc": "tsc",
		"lint": "eslint . --fix --ext .js,.jsx,.ts,.tsx",
		"device:help": "agent-device --help",
		"device:boot:ios": "agent-device boot --platform ios",
		"device:boot:android": "agent-device boot --platform android",
		"device:apps:ios": "agent-device apps --platform ios",
		"device:apps:android": "agent-device apps --platform android",
		"device:snapshot": "agent-device snapshot -i",
		"devtools:start": "agent-react-devtools start",
		"devtools:status": "agent-react-devtools status",
		"devtools:stop": "agent-react-devtools stop",
		"skills:list": "npx skills list",
		"skills:restore": "npx skills add callstackincubator/agent-skills --skill react-native-best-practices --agent codex -y && npx skills add callstackincubator/agent-react-devtools --skill react-devtools --agent codex -y && npx skills add callstackincubator/agent-device --skill agent-device --agent codex -y",
		"postinstall": "patch-package",
		"docs:dev": "vuepress dev docs",
		"docs:build": "vuepress build docs"
	},
	"workspaces": [
		"packages/*"
	],
	"dependencies": {
		"@react-native-community/hooks": "^3.1.0",
		"@react-native-community/slider": "^5.1.0",
		"@sdcx/keyboard-insets": "^1.0.5",
		"hybrid-navigation": "*",
		"react": "19.2.3",
		"react-native": "0.85.2",
		"react-native-safe-area-context": "^5.5.2"
	},
	"devDependencies": {
		"@babel/core": "^7.25.2",
		"@babel/preset-env": "^7.25.3",
		"@babel/runtime": "^7.25.0",
		"@react-native-community/cli": "20.1.0",
		"@react-native-community/cli-platform-android": "20.1.0",
		"@react-native-community/cli-platform-ios": "20.1.0",
		"@react-native/babel-preset": "0.85.2",
		"@react-native/eslint-config": "0.85.2",
		"@react-native/jest-preset": "0.85.2",
		"@react-native/metro-config": "0.85.2",
		"@react-native/typescript-config": "0.85.2",
		"@types/jest": "^29.5.13",
		"@types/react": "^19.2.0",
		"@types/react-test-renderer": "^19.1.0",
		"agent-device": "^0.12.9",
		"agent-react-devtools": "^0.4.0",
		"babel-plugin-module-resolver": "^5.0.2",
		"eslint": "^8.19.0",
		"jest": "^29.6.3",
		"patch-package": "^8.0.0",
		"postinstall-postinstall": "^2.1.0",
		"prettier": "2.8.8",
		"react-test-renderer": "19.2.3",
		"typescript": "^5.8.3",
		"vuepress": "2.0.0-beta.51"
	},
	"engines": {
		"node": ">=20.19.4"
	}
}
